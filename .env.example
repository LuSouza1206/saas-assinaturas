# Database
DATABASE_URL="postgresql://saas:saas_secret@localhost:5432/saas_assinaturas?schema=public"

# Redis (Docker: host 6380 → container 6379)
REDIS_URL="redis://127.0.0.1:6380"

# API
API_PORT=4000
API_URL=http://localhost:4000
NODE_ENV=development

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:4000
FRONTEND_URL=http://localhost:3000

# Auth
JWT_SECRET=change-me-to-a-long-random-secret-in-production
JWT_EXPIRES_IN=7d

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/auth/oauth/google/callback

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# Sentry
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# Email (sem chave, jobs só logam no console)
RESEND_API_KEY=
EMAIL_FROM="Ledgerflow <onboarding@resend.dev>"
